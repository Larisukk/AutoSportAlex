---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina nu a fost găsită">
  <div class="min-h-[70vh] flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 bg-slate-50">
    <div class="max-w-max mx-auto text-center">
      <main class="sm:flex">
        <p class="text-5xl font-extrabold text-autosport-red sm:text-6xl tracking-tight">404</p>
        <div class="sm:ml-6 sm:border-l sm:border-slate-300 sm:pl-6 sm:pt-1">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-autosport-navy tracking-tight mb-2">Pagină inexistentă</h1>
          <p class="text-lg text-slate-600 mb-6">Ne pare rău, dar pagina pe care ai cerut-o pare să fie în afara traseului.</p>
          <div class="flex space-x-4 sm:border-l sm:border-transparent">
            <a href="/" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-semibold rounded-lg text-text-on-dark bg-autosport-navy-dark hover:bg-autosport-navy transition-colors">
              Înapoi pe Prima Pagină
            </a>
            <a href="/contact" class="inline-flex items-center px-6 py-3 border border-slate-300 text-base font-semibold rounded-lg text-autosport-navy hover:bg-autosport-navy hover:text-white transition-colors">
              Contact
            </a>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

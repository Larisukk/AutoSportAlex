---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../content/site';
---

<Layout title="Contact" description="Ia legătura cu noi pentru înscrieri, oferte și detalii despre școala de șoferi AutoSport Alex.">
  <div class="bg-autosport-navy-dark py-16 border-b border-autosport-border relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[linear-gradient(45deg,#ffffff_1px,transparent_1px),linear-gradient(-45deg,#ffffff_1px,transparent_1px)] bg-[length:20px_20px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-on-dark mb-4">Contact</h1>
      <p class="text-xl text-text-muted max-w-2xl mx-auto">Suntem aici să iți răspundem la orice întrebare legată de școala de șoferi.</p>
    </div>
  </div>

  <section class="py-20 bg-slate-50 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 mb-20">
        
        <!-- Contact Info Cards -->
        <div class="space-y-8">
          <div>
            <h2 class="text-autosport-red font-bold tracking-wide uppercase text-sm mb-2">Informații de Contact</h2>
            <h3 class="text-3xl font-extrabold text-autosport-navy mb-8">Ne găsești ușor în Slatina</h3>
          </div>
          
          <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-start group">
            <div class="w-12 h-12 bg-red-50 text-autosport-red rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-autosport-red group-hover:text-text-on-dark transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-bold text-slate-800 mb-1">Adresa Sediu</h4>
              <p class="text-slate-600">{siteConfig.address}<br/>{siteConfig.city}, {siteConfig.country}</p>
              <a href={siteConfig.mapUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-autosport-red mt-3 hover:text-autosport-navy transition-colors">
                Deschide Google Maps
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
            </div>
          </div>
          
          <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-start group">
            <div class="w-12 h-12 bg-red-50 text-autosport-red rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-autosport-red group-hover:text-text-on-dark transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-bold text-slate-800 mb-1">Telefon</h4>
              <p class="text-slate-600">Disponibili Luni - Vineri: 09:00 - 18:00</p>
              <div class="flex gap-4 mt-3">
                <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="inline-flex items-center text-sm font-semibold text-autosport-red hover:text-autosport-navy transition-colors">
                  Sună: {siteConfig.phone}
                </a>
                <a href={`https://wa.me/4${siteConfig.phone.replace(/\s+/g, '')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-green-600 hover:text-green-700 transition-colors">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                  WhatsApp
                </a>
              </div>
            </div>
          </div>
          
          <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-start group">
            <div class="w-12 h-12 bg-red-50 text-autosport-red rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-autosport-red group-hover:text-text-on-dark transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div class="ml-4">
              <h4 class="text-lg font-bold text-slate-800 mb-1">Email</h4>
              <p class="text-slate-600">Ne poți scrie oricând, răspundem rapid.</p>
              <a href={`mailto:${siteConfig.email}`} class="inline-flex items-center text-sm font-semibold text-autosport-red mt-3 hover:text-autosport-navy transition-colors">
                {siteConfig.email}
              </a>
            </div>
          </div>
        </div>

        <!-- Form Area -->
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-tr from-autosport-red/5 to-autosport-red/10 rounded-[2.5rem] -z-10 transform -rotate-1"></div>
          <ContactForm />
        </div>
        
      </div>

    </div>
  </section>
  
  <!-- Map Iframe Embedded -->
  <section class="border-t border-slate-200">
    <div class="w-full h-96 bg-slate-200 relative">
      <div class="absolute inset-0 flex items-center justify-center text-text-muted -z-10">Încărcare hartă...</div>
      <!-- Simplest, free map solution: Google Maps iframe. 
           (Replaced coordinates query with standard place embedding if available, otherwise generic coordinates) -->
      <iframe 
        src="https://maps.google.com/maps?q=Scoala+de+Soferi+AutoSport+Alex,+Slatina&t=&z=16&ie=UTF8&iwloc=&output=embed" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title="Locația sediului AutoSport Alex pe hartă"
        class="w-full h-full"
      ></iframe>
    </div>
  </section>
</Layout>

---
import { siteConfig } from '../content/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-autosport-navy-dark text-text-muted py-12 border-t border-autosport-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
    
    <!-- Branding & Info -->
    <div>
      <a href="/" class="inline-block mb-4">
        <img src="/images/logo.webp" alt="AutoSport Alex Logo" class="h-12 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity" />
      </a>
      <p class="text-sm text-text-muted mb-6">
        {siteConfig.description}
      </p>
      <div class="flex space-x-4">
        <a href={siteConfig.socials.facebook} class="text-text-muted hover:text-text-on-dark transition-colors">
          <span class="sr-only">Facebook</span>
          <!-- FB Icon -->
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <h3 class="text-sm font-semibold text-text-on-dark tracking-wider uppercase mb-4">Linkuri utile</h3>
      <ul class="space-y-3">
        <li><a href="/despre-noi" class="text-sm hover:text-autosport-red transition-colors">Despre Noi</a></li>
        <li><a href="/instructori" class="text-sm hover:text-autosport-red transition-colors">Echipa Noastră</a></li>
        <li><a href="/galerie" class="text-sm hover:text-autosport-red transition-colors">Galerie Foto / Video</a></li>
        <li><a href="/contact" class="text-sm hover:text-autosport-red transition-colors">Contact</a></li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div>
      <h3 class="text-sm font-semibold text-text-on-dark tracking-wider uppercase mb-4">Contact</h3>
      <ul class="space-y-4">
        <li class="flex items-start">
          <svg class="flex-shrink-0 w-5 h-5 text-autosport-red mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="ml-3 text-sm">{siteConfig.fullAddress}</span>
        </li>
        <li class="flex items-center">
          <svg class="flex-shrink-0 w-5 h-5 text-autosport-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="ml-3 text-sm hover:text-autosport-red transition-colors">{siteConfig.phone}</a>
        </li>
        <li class="flex items-center">
          <svg class="flex-shrink-0 w-5 h-5 text-autosport-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href={`mailto:${siteConfig.email}`} class="ml-3 text-sm hover:text-autosport-red transition-colors">{siteConfig.email}</a>
        </li>
      </ul>
    </div>

  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 pt-8 border-t border-autosport-border flex flex-col md:flex-row justify-between items-center text-xs text-slate-500">
    <p>&copy; {currentYear} {siteConfig.name}. Toate drepturile rezervate.</p>
    <p class="mt-2 md:mt-0">Dezvoltat cu ♥ pentru cursanții noștri</p>
  </div>
</footer>

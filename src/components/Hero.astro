---
import { siteConfig } from '../content/site';
---

<section class="relative bg-autosport-navy-dark overflow-hidden min-h-[85vh] flex flex-col justify-center bg-cover bg-center" style="background-image: url('/images/hero-bg.webp');">
  <!-- Dark Navy Overlay -->
  <div class="absolute inset-0 z-10" style="background: linear-gradient(rgba(11,27,51,0.85), rgba(11,27,51,0.75));"></div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 flex flex-col items-center justify-center text-center">
    
    <span class="inline-flex items-center px-3 py-1 rounded-full bg-autosport-surface border border-autosport-border text-text-muted text-sm font-semibold tracking-wide uppercase mb-6">
      Școala de șoferi în {siteConfig.city}
    </span>
    
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white tracking-tight mb-8 max-w-4xl leading-tight">
      Drumul tău spre permis începe cu <span class="relative inline-block">profesioniști<div class="absolute -bottom-2 left-0 w-full h-[3px] bg-autosport-red rounded-full"></div></span>
    </h1>
    
    <p class="mt-4 text-xl md:text-2xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed font-light">
      Pregătire teoretică și practică completă pentru categoriile B, C, CE și altele. Instructori răbdători, program flexibil și autovehicule moderne.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/contact" class="w-full sm:w-auto px-8 py-4 bg-autosport-red hover:bg-autosport-red-hover text-white font-bold rounded-lg shadow-sm transition-all duration-200 text-lg flex items-center justify-center">
        Înscrie-te Acum
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      
      <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="w-full sm:w-auto px-8 py-4 bg-transparent hover:bg-white/5 border border-autosport-border text-white font-semibold rounded-lg transition-all duration-200 text-lg flex items-center justify-center backdrop-blur-sm">
        <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Sună: {siteConfig.phone}
      </a>
    </div>
    
    <!-- Trust Badges -->
    <div class="mt-16 pt-8 border-t border-autosport-border flex flex-wrap justify-center gap-8 md:gap-16">
      <div class="flex items-center text-text-muted">
        <svg class="w-6 h-6 text-autosport-red mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
        <span class="font-medium">Instructori experimentați</span>
      </div>
      <div class="flex items-center text-text-muted">
        <svg class="w-6 h-6 text-autosport-red mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span class="font-medium">Pregătire completă</span>
      </div>
      <div class="flex items-center text-text-muted">
        <svg class="w-6 h-6 text-autosport-red mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="font-medium">Program flexibil</span>
      </div>
    </div>
  </div>
</section>

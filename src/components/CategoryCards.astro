---
import { categories } from '../content/categories';

// Simple helper to pick an icon based on string from content
const iconMap: Record<string, string> = {
  car: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h8M4 11h16a2 2 0 012 2v4a2 2 0 01-2 2h-2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2H2a2 2 0 01-2-2v-4a2 2 0 012-2zm4 6a2 2 0 100-4 2 2 0 000 4zm8 0a2 2 0 100-4 2 2 0 000 4z"/></svg>`,
  truck: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h10V5a2 2 0 00-2-2H4a2 2 0 00-2 2v10h2m10-8h4a2 2 0 012 2v5h-2M4 15v2a2 2 0 002 2h2m10-4v4m-4-4v4m0-4a2 2 0 100 4 2 2 0 000-4zm-10 0a2 2 0 100 4 2 2 0 000-4z"/></svg>`,
  motorcycle: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5zm0 0l-3 4-4 2m7-6l3 4 4 2m-7 4v5m0-5h-4m4 0h4M5 13a4 4 0 110 8 4 4 0 010-8zm14 0a4 4 0 110 8 4 4 0 010-8z"/></svg>`
};
---

<section class="py-20 bg-slate-50" id="categorii">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-autosport-red font-bold tracking-wide uppercase text-sm mb-2">Pachete de școlarizare</h2>
      <h3 class="text-3xl md:text-4xl font-extrabold text-autosport-navy mb-4">Alege categoria potrivită pentru tine</h3>
      <p class="text-lg text-slate-600">Oferim cursuri teoretice și practice pentru a te ajuta să obții permisul de conducere dorit, în cel mai scurt timp.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {categories.map((cat) => (
        <div class="bg-white rounded-2xl p-8 border border-slate-200 hover:-translate-y-1 transition-all duration-300 group flex flex-col h-full">
          <div class="w-16 h-16 bg-red-50 text-autosport-red rounded-2xl flex items-center justify-center mb-6 group-hover:bg-autosport-red group-hover:text-text-on-dark transition-colors duration-300">
            <Fragment set:html={iconMap[cat.icon] || iconMap.car} />
          </div>
          <h4 class="text-2xl font-bold text-autosport-navy mb-2">{cat.name}</h4>
          <p class="text-autosport-red font-medium text-sm mb-4">{cat.title}</p>
          <p class="text-slate-600 mb-6 flex-grow">{cat.description}</p>
          <div class="bg-slate-50 rounded-lg p-4 mt-auto mb-6">
            <span class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Pentru cine este:</span>
            <span class="text-sm text-slate-700">{cat.forWho}</span>
          </div>
          <a href="/contact" class="inline-flex items-center justify-center w-full py-3 px-4 border border-autosport-border rounded-xl text-autosport-navy font-semibold hover:bg-autosport-navy hover:text-white transition-colors">
            Află detalii
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

---
// ContactForm.astro
// Using Formspree as the free, easy solution for static sites on Cloudflare Pages
// The user just needs to register on Formspree.io and paste their form ID here, 
// or set it as an environment variable building on CF Pages.
const formAction = import.meta.env.PUBLIC_FORMSPREE_URL || "https://formspree.io/f/YOUR_FORM_ID_HERE";
---

<div class="bg-white rounded-2xl shadow-xl p-8 border border-slate-100">
  <div class="mb-8">
    <h3 class="text-2xl font-bold text-autosport-navy">Trimite-ne un mesaj</h3>
    <p class="text-slate-600 mt-2">Ai întrebări sau vrei să te înscrii? Completează formularul și te vom contacta în cel mai scurt timp.</p>
  </div>

  <form action={formAction} method="POST" class="space-y-6" id="contactForm">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Nume complet</label>
        <input 
          type="text" 
          name="name" 
          id="name" 
          required 
          class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-autosport-red focus:border-autosport-red transition-colors outline-none"
          placeholder="ex: Ion Popescu"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Adresă de email</label>
        <input 
          type="email" 
          name="email" 
          id="email" 
          required 
          class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-autosport-red focus:border-autosport-red transition-colors outline-none"
          placeholder="ex: ion.popescu@email.com"
        />
      </div>
    </div>
    
    <div>
      <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">Subiect</label>
      <input 
        type="text" 
        name="subject" 
        id="subject" 
        required
        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-autosport-red focus:border-autosport-red transition-colors outline-none"
        placeholder="ex: Înscriere Categoria B / Întrebare curs"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Mesajul tău</label>
      <textarea 
        name="message" 
        id="message" 
        rows="4" 
        required
        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-autosport-red focus:border-autosport-red transition-colors outline-none resize-none"
        placeholder="Scrie aici detaliile mesajului tău..."
      ></textarea>
    </div>

    <!-- Honeypot field to prevent spam bots -->
    <input type="text" name="_gotcha" style="display:none" />
    <!-- Formspree internal settings (optional) -->
    <input type="hidden" name="_subject" value="Mesaj nou de pe site-ul AutoSport Alex!" />

    <button 
      type="submit" 
      class="w-full bg-autosport-red hover:bg-autosport-red-hover text-white font-bold py-4 px-8 rounded-lg transition-colors shadow-sm flex justify-center items-center group"
    >
      <span>Trimite Mesajul</span>
      <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </button>
    
    <p class="text-xs text-slate-500 text-center mt-4">
      Prin trimiterea acestui formular, ești de acord ca datele tale să fie procesate pentru a fi contactat în legătură cu solicitarea ta.
    </p>
  </form>
</div>

---
const steps = [
  {
    num: "01",
    title: "Înscrierea",
    desc: "Vino la sediul nostru cu documentele necesare și completează fișa de înscriere."
  },
  {
    num: "02",
    title: "Cursul de Legislație",
    desc: "Participă la orele de teorie pentru a învăța regulile de circulație și a fi pregătit pentru sală."
  },
  {
    num: "03",
    title: "Pregătirea Practică",
    desc: "Începi orele de condus alături de instructorul tău pe traseele din oraș."
  },
  {
    num: "04",
    title: "Examenul",
    desc: "Susții examenul teoretic (sala) și pe cel practic (traseul). Felicitări, ești șofer!"
  }
];
---

<section class="py-20 bg-white border-y border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-autosport-red font-bold tracking-wide uppercase text-sm mb-2">Proces Simplificat</h2>
      <h3 class="text-3xl md:text-4xl font-extrabold text-autosport-navy mb-4">Cum funcționează?</h3>
      <p class="text-lg text-slate-600">Obținerea permisului tău auto este un proces clar și structurat la școala noastră.</p>
    </div>

    <div class="relative">
      <!-- Connection Line (desktop only) -->
      <div class="hidden lg:block absolute top-12 left-0 w-full h-0.5 bg-slate-100" aria-hidden="true"></div>
      
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        {steps.map((step) => (
          <div class="relative pt-8 lg:pt-0 group">
            <div class="lg:absolute lg:top-8 left-1/2 lg:-translate-x-1/2 w-16 h-16 bg-white border-4 border-slate-100 rounded-full flex items-center justify-center text-xl font-black text-text-muted group-hover:border-autosport-red group-hover:text-autosport-red transition-colors duration-300 z-10 mx-auto lg:mx-0 mb-6 lg:mb-0 lg:-mt-8 shadow-sm group-hover:shadow-md">
              {step.num}
            </div>
            
            <div class="text-center lg:mt-12 bg-slate-50/50 p-6 rounded-2xl lg:bg-transparent lg:p-0 border border-slate-100 lg:border-none">
              <h4 class="text-xl font-bold text-autosport-navy mb-3">{step.title}</h4>
              <p class="text-slate-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

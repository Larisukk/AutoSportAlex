---
import { reviews } from '../content/reviews';
import { siteConfig } from '../content/site';

// Use basic CSS scroll-snap for carousel instead of heavy JS library
---

<section class="py-24 bg-autosport-navy-dark" id="recenzii">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 border-b border-autosport-border pb-8">
      <div class="max-w-2xl">
        <h2 class="text-autosport-red font-bold tracking-wide uppercase text-sm mb-2">Părerile Cursanților</h2>
        <h3 class="text-3xl md:text-4xl font-extrabold text-text-on-dark">Ce spun cei care au obținut permisul cu noi</h3>
      </div>
      <a href={siteConfig.mapUrl} target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center text-autosport-red hover:text-text-on-dark font-medium transition-colors">
        Vezi toate recenziile pe Google
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    </div>

    <!-- Carousel Container -->
    <div class="relative group">
      <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-8 -mx-4 px-4 sm:mx-0 sm:px-0 gap-6" id="reviews-slider">
        <!-- Spacer for left side -->
        <div class="shrink-0 w-2 lg:w-16"></div>
        
        {reviews.map((review) => (
          <div class="snap-center shrink-0 w-[85vw] sm:w-[500px] bg-autosport-surface hover:bg-white/10 rounded-2xl p-8 border border-autosport-border flex flex-col">
            <div class="flex items-center mb-6">
              <div class="w-12 h-12 bg-gradient-to-br from-autosport-red to-autosport-red-hover rounded-full flex items-center justify-center text-white font-bold text-lg shadow-inner">
                {review.authorName.charAt(0)}
              </div>
              <div class="ml-4">
                <h4 class="text-text-on-dark font-bold">{review.authorName}</h4>
                <div class="flex items-center text-autosport-red mt-1">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-4 h-4 ${i < review.rating ? 'text-autosport-red' : 'text-slate-600'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                  <span class="ml-2 text-xs text-text-muted font-medium">{review.date}</span>
                </div>
              </div>
            </div>
            <p class="text-text-muted italic flex-grow">"{review.text}"</p>
            <div class="mt-6 flex items-center text-xs text-slate-500 font-semibold tracking-wider">
              <svg class="w-4 h-4 mr-1 text-text-muted" viewBox="0 0 24 24" fill="currentColor">
                <path d="M21.35,11.1H12.18V13.83H18.69C18.36,15.05 17.26,16.36 15.05,17.3L15.05,19.25H18.96C21.25,17.14 22.5,14.07 22.5,10.64C22.5,10.13 22.45,9.66 22.35,9.22L21.35,11.1Z" />
                <path d="M12.18,22.5C15.08,22.5 17.5,21.54 19.3,19.89L15.35,17.34C14.38,18 13.34,18.33 12.18,18.33C9.36,18.33 6.96,16.42 6.13,13.88H2.1V16.92C3.96,20.62 7.82,22.5 12.18,22.5Z" />
                <path d="M6.13,10.66C5.92,10.04 5.8,9.39 5.8,8.81C5.8,8.19 5.92,7.54 6.13,6.92V3.88H2.1C1.34,5.42 0.89,7.06 0.89,8.81C0.89,10.5 1.34,12.14 2.1,13.68L6.13,10.66Z" />
                <path d="M12.18,3.2C13.84,3.2 15.2,3.77 16.32,4.8L19.26,1.86C17.43,0.18 15.02,-0.5 12.18,-0.5C7.82,-0.5 3.96,1.38 2.1,5.08L6.13,8.12C6.96,5.58 9.36,3.2 12.18,3.2Z" />
              </svg>
              Sursa: Google Reviews
            </div>
          </div>
        ))}
        
        <!-- Spacer for right side -->
        <div class="shrink-0 w-2 lg:w-16"></div>
      </div>
      
      <!-- Navigation Buttons -->
      <button id="prev-review" class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-autosport-navy border border-autosport-border hover:bg-autosport-red text-white hover:border-autosport-red rounded-full items-center justify-center transition-all z-10 shadow-lg focus:outline-none" aria-label="Recenzie anterioară">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>

      <button id="next-review" class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-autosport-navy border border-autosport-border hover:bg-autosport-red text-white hover:border-autosport-red rounded-full items-center justify-center transition-all z-10 shadow-lg focus:outline-none" aria-label="Recenzie următoare">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
      
      <!-- Fade edges for desktop -->
      <div class="hidden lg:block absolute top-0 bottom-0 left-0 w-24 bg-gradient-to-r from-autosport-navy-dark to-transparent pointer-events-none"></div>
      <div class="hidden lg:block absolute top-0 bottom-0 right-0 w-24 bg-gradient-to-l from-autosport-navy-dark to-transparent pointer-events-none"></div>
    </div>
    
    <div class="mt-8 md:hidden text-center">
      <a href={siteConfig.mapUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-autosport-red hover:text-text-on-dark font-medium transition-colors">
        Vezi toate recenziile pe Google
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hide-scrollbar {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('reviews-slider');
    const btnPrev = document.getElementById('prev-review');
    const btnNext = document.getElementById('next-review');

    if (slider && btnPrev && btnNext) {
      // Approximate scroll amount (card width + gap)
      const scrollAmount = window.innerWidth < 768 ? window.innerWidth * 0.85 : 524; 

      btnPrev.addEventListener('click', () => {
        slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      btnNext.addEventListener('click', () => {
        slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  });
</script>
